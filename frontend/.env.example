NEXT_PUBLIC_SITE_URL=https://kuboqss.com
NEXT_PUBLIC_API_URL=https://api.kuboqss.com

# Server-side only: Next.js proxies POST /api/orders to this URL (use EasyPanel internal URL if needed)
BACKEND_URL=http://kuboqss-backend:8000

# Browser pixel IDs only. Do not put server access tokens here.
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_CODE=
NEXT_PUBLIC_SNAP_PIXEL_ID=

# Optional public flags
NEXT_PUBLIC_ENABLE_PIXELS=true
